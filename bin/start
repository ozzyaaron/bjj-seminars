#!/usr/bin/env ruby

require 'fileutils'
require 'pathname'

# Path to your application root
APP_ROOT = Pathname.new File.expand_path('..', __dir__)

def system!(*args)
  system(*args) || abort("\n== Command #{args} failed ==")
end

def log(message)
  puts "\n== #{message} =="
end

def check_dependencies
  log "Checking dependencies"
  
  # Check if Rails is available
  unless system('bundle exec rails --version > /dev/null 2>&1')
    abort "Rails not found. Please run 'bundle install' first."
  end
  
  # Check if database exists
  unless File.exist?(APP_ROOT.join('db/development.sqlite3'))
    log "Database not found. Setting up database..."
    system! 'bin/rails db:prepare'
  end
  
  # Check if Active Storage tables exist
  begin
    require_relative '../config/environment'
    ActiveRecord::Base.connection.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='active_storage_blobs';")
  rescue ActiveRecord::StatementInvalid
    log "Active Storage tables not found. Running migrations..."
    system! 'bin/rails db:migrate'
  end
end

def start_services
  log "Starting BJJ Seminar Tracker services"
  
  FileUtils.chdir APP_ROOT do
    # Kill any existing Rails processes on port 3000
    log "Stopping any existing Rails processes"
    system("lsof -ti:3000 | xargs kill -9 2>/dev/null || true")
    
    # Ensure assets are compiled for development
    log "Preparing assets"
    if File.exist?('config/tailwind.config.js')
      system! 'bin/rails tailwindcss:build'
    end
    
    # Start the Rails server
    log "Starting Rails server on http://localhost:3000"
    puts "\n" + "="*60
    puts "🥋 BJJ Seminar Tracker is starting up!"
    puts "="*60
    puts "📍 Application will be available at: http://localhost:3000"
    puts "🔒 Admin features available to admin users"
    puts "📸 Image uploads supported (up to 10 per seminar)"
    puts "⚡ Rate limiting: 25 seminars per user per day"
    puts "🛡️  Security: IP-based registration limits (1 per day)"
    puts "="*60
    puts "\n💡 Quick Start:"
    puts "   • Visit http://localhost:3000 to see the home page"
    puts "   • Click 'Sign up' to create an account"
    puts "   • Create seminars with instructors and images"
    puts "   • Browse teams and players"
    puts "\n🛑 To stop the server: Press Ctrl+C"
    puts "="*60
    puts ""
    
    # Start server with proper environment
    env = {
      'RAILS_ENV' => ENV.fetch('RAILS_ENV', 'development'),
      'PORT' => '3000'
    }
    
    exec(env, 'bin/rails', 'server', '-p', '3000', '-b', '0.0.0.0')
  end
end

def show_usage
  puts <<~USAGE
    BJJ Seminar Tracker Startup Script
    
    Usage: bin/start [options]
    
    Options:
      --help, -h     Show this help message
      --check        Check dependencies only (don't start)
      --port PORT    Start on specific port (default: 3000)
      
    Environment Variables:
      RAILS_ENV      Set the Rails environment (default: development)
      PORT           Set the port number (default: 3000)
      
    Examples:
      bin/start                    # Start on port 3000
      bin/start --port 3001        # Start on port 3001
      RAILS_ENV=production bin/start # Start in production mode
      
    Services Started:
      • Rails application server
      • Active Storage (for image uploads)
      • SQLite database
      • TailwindCSS asset compilation
      • Rate limiting (Rack::Attack)
      
    Application Features:
      ✅ User authentication with secure passwords
      ✅ Seminar creation and management
      ✅ Player and team management (admin only)
      ✅ Image uploads with variants (thumb, medium, large)
      ✅ Search and filtering
      ✅ Rate limiting and security features
      ✅ Responsive design with TailwindCSS
      ✅ Progressive Web App ready
  USAGE
end

# Parse command line arguments
case ARGV[0]
when '--help', '-h'
  show_usage
  exit 0
when '--check'
  check_dependencies
  log "All dependencies check out! ✅"
  exit 0
when '--port'
  ENV['PORT'] = ARGV[1] if ARGV[1]
else
  # Default behavior
end

# Main execution
begin
  check_dependencies
  start_services
rescue Interrupt
  log "Shutting down BJJ Seminar Tracker"
  puts "\n👋 Thanks for using BJJ Seminar Tracker!"
  exit 0
rescue => e
  puts "\n❌ Error starting application: #{e.message}"
  puts "\nTry running:"
  puts "  bundle install          # Install dependencies"
  puts "  bin/rails db:prepare     # Setup database"
  puts "  bin/start --check       # Check system status"
  exit 1
end